# ── 필수 ──────────────────────────────────────────────────────────

# Rails master key (backend/config/master.key 파일 내용)
RAILS_MASTER_KEY=

# Secret key base (cd backend && bin/rails secret 으로 생성)
# devise-jwt 토큰 서명에도 사용되므로 유출/변경 주의 (변경 시 전 유저 로그아웃)
SECRET_KEY_BASE=

# RDS PostgreSQL 연결 URL
DATABASE_URL=postgresql://yovo:password@your-rds-endpoint.rds.amazonaws.com:5432/yovo_production

# ── 도메인/보안 (운영 배포 시 반드시 설정) ─────────────────────────

# 서비스 도메인 — 메일 링크·절대 URL 생성에 사용
# 예: APP_HOST=yovo.example.com
APP_HOST=

# CORS 허용 오리진 (콤마 구분). 비우면 전체 허용(*)이므로 운영에서는 반드시 설정.
# 같은 도메인에서 nginx 프록시로 서빙하는 기본 구성에서는 브라우저가 CORS를 타지
# 않지만, 토큰 탈취 시 임의 사이트에서의 API 호출을 막는 방어선이 된다.
# 예: CORS_ORIGINS=https://yovo.example.com,https://www.yovo.example.com
CORS_ORIGINS=

# ALB/CloudFront 등에서 TLS(HTTPS)를 종료하고 EC2로 HTTP 포워딩하는 구성이면 true.
# HTTPS 리다이렉트 + HSTS + secure 쿠키가 켜진다. (헬스체크 /up은 제외)
# EC2에 도메인 없이 HTTP로만 접근하는 동안은 false 유지.
FORCE_SSL=false

# ── 선택 ──────────────────────────────────────────────────────────

# 로그 레벨 (debug / info / warn / error)
RAILS_LOG_LEVEL=info

# API를 프론트와 다른 도메인으로 분리할 때만 설정 (프론트 빌드 타임에 주입).
# 기본(비움)은 같은 오리진 — frontend nginx가 /api·/rails를 backend로 프록시한다.
# 예: VITE_API_BASE_URL=https://api.yovo.example.com
VITE_API_BASE_URL=
