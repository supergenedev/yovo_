<% content_for :page_title, '유저 관리' %>
<div class="page-header">
  <h1>유저 <span style="color:#94a3b8; font-weight:400; font-size:15px;"><%= @pagy.count %>명</span></h1>
</div>

<div class="card">
  <table>
    <thead>
      <tr><th>ID</th><th>이메일</th><th>닉네임</th><th>유저명</th><th>가입일</th><th></th></tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td style="color:#94a3b8; font-size:12px;"><%= user.id %></td>
          <td><%= link_to user.email, admin_user_path(user), style: 'color:#6366f1;' %></td>
          <td><%= user.nickname %></td>
          <td style="color:#64748b;">@<%= user.username %></td>
          <td style="color:#64748b;"><%= user.created_at.strftime('%Y.%m.%d') %></td>
          <td>
            <%= button_to '삭제', admin_user_path(user), method: :delete,
                data: { turbo_confirm: "#{user.email}을 삭제할까요?" },
                class: 'btn btn-danger btn-sm' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
</div>
