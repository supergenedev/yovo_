<% content_for :page_title, '대시보드' %>

<div class="stats-grid">
  <div class="stat-card">
    <div class="label">유저</div>
    <div class="value"><%= number_with_delimiter(@stats[:users]) %></div>
  </div>
  <div class="stat-card">
    <div class="label">크리에이터</div>
    <div class="value"><%= number_with_delimiter(@stats[:creators]) %></div>
  </div>
  <div class="stat-card">
    <div class="label">포스트</div>
    <div class="value"><%= number_with_delimiter(@stats[:posts]) %></div>
  </div>
  <div class="stat-card">
    <div class="label">댓글</div>
    <div class="value"><%= number_with_delimiter(@stats[:comments]) %></div>
  </div>
  <div class="stat-card">
    <div class="label">팔로우</div>
    <div class="value"><%= number_with_delimiter(@stats[:follows]) %></div>
  </div>
  <div class="stat-card">
    <div class="label">알림</div>
    <div class="value"><%= number_with_delimiter(@stats[:notifications]) %></div>
  </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
  <div class="card">
    <div class="card-header"><h3>최근 가입 유저</h3></div>
    <table>
      <thead><tr><th>이메일</th><th>닉네임</th><th>가입일</th></tr></thead>
      <tbody>
        <% @recent_users.each do |user| %>
          <tr>
            <td><%= link_to user.email, admin_user_path(user), style: 'color: #6366f1;' %></td>
            <td><%= user.nickname %></td>
            <td><%= user.created_at.strftime('%m.%d') %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <div class="card-header"><h3>최근 포스트</h3></div>
    <table>
      <thead><tr><th>제목</th><th>크리에이터</th><th>등록일</th></tr></thead>
      <tbody>
        <% @recent_posts.each do |post| %>
          <tr>
            <td><%= link_to truncate(post.title_ko, length: 20), admin_post_path(post), style: 'color: #6366f1;' %></td>
            <td><%= post.creator_user&.nickname %></td>
            <td><%= post.created_at.strftime('%m.%d') %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
