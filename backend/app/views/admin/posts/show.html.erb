<% content_for :page_title, '포스트 상세' %>
<div class="page-header">
  <h1><%= truncate(@post.title_ko, length: 40) %></h1>
  <%= link_to '← 목록', admin_posts_path, class: 'btn btn-ghost btn-sm' %>
</div>

<div class="detail-grid">
  <div class="card" style="padding: 20px;">
    <h3 style="font-size:13px; font-weight:600; margin-bottom:16px; color:#64748b; text-transform:uppercase; letter-spacing:0.5px;">포스트 정보</h3>
    <div class="detail-item"><label>제목</label><span><%= @post.title_ko %></span></div>
    <div class="detail-item"><label>크리에이터</label><span><%= @post.creator_user&.nickname %></span></div>
    <div class="detail-item"><label>공개 유형</label><span><%= @post.view_type %></span></div>
    <div class="detail-item"><label>콘텐츠 유형</label><span><%= @post.content_type %></span></div>
    <div class="detail-item"><label>상태</label><span><%= @post.status %></span></div>
    <div class="detail-item"><label>좋아요</label><span><%= @post.likes_count %></span></div>
    <div class="detail-item"><label>댓글</label><span><%= @post.comments_count %></span></div>
    <div class="detail-item"><label>등록일</label><span><%= @post.created_at.strftime('%Y.%m.%d %H:%M') %></span></div>
  </div>
  <div class="card" style="padding: 20px;">
    <h3 style="font-size:13px; font-weight:600; margin-bottom:16px; color:#64748b; text-transform:uppercase; letter-spacing:0.5px;">본문</h3>
    <p style="font-size:14px; color:#334155; line-height:1.7; white-space:pre-wrap;"><%= @post.body_ko %></p>
  </div>
</div>

<% if @issues.any? %>
<div class="card">
  <div class="card-header"><h3>이 포스트에 대한 신고 (<%= @issues.count %>)</h3></div>
  <table>
    <thead><tr><th>사유</th><th>신고자</th><th>신고일</th><th>상태</th><th></th></tr></thead>
    <tbody>
      <% @issues.each do |issue| %>
        <tr>
          <td><span class="badge badge-yellow"><%= issue.issue_reason %></span></td>
          <td><%= issue.user&.nickname %></td>
          <td style="color:#64748b;"><%= issue.created_at.strftime('%Y.%m.%d') %></td>
          <td><span class="badge <%= issue.resolved? ? 'badge-green' : 'badge-red' %>"><%= issue.resolved? ? '처리완료' : '미처리' %></span></td>
          <td>
            <% unless issue.resolved? %>
              <%= button_to '처리 완료', resolve_admin_issue_path(issue), method: :patch, class: 'btn btn-primary btn-sm' %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% end %>

<div class="card">
  <div class="card-header"><h3>댓글 (최근 20개)</h3></div>
  <table>
    <thead><tr><th>내용</th><th>작성자</th><th>작성일</th><th></th></tr></thead>
    <tbody>
      <% @comments.each do |comment| %>
        <tr>
          <td style="max-width:360px;"><%= truncate(comment.text, length: 60) %></td>
          <td><%= comment.commenter.try(:nickname) || comment.commenter.try(:email) %></td>
          <td style="color:#64748b;"><%= comment.created_at.strftime('%Y.%m.%d %H:%M') %></td>
          <td>
            <%= button_to '삭제', admin_post_comment_path(comment), method: :delete,
                data: { turbo_confirm: '이 댓글을 삭제할까요?' },
                class: 'btn btn-danger btn-sm' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @comments.empty? %>
    <div class="empty-state">댓글이 없습니다</div>
  <% end %>
</div>
