<% content_for :page_title, '로그인' %>
<div class="login-page" style="margin: -32px; min-height: calc(100vh);">
  <div class="login-box">
    <h1>YOVO Admin</h1>
    <p>관리자 계정으로 로그인하세요</p>

    <%= form_with url: admin_login_path, local: true do |f| %>
      <div class="form-group">
        <%= f.label :email, '이메일' %>
        <%= f.email_field :email, placeholder: 'admin@yovo.dev', autocomplete: 'email' %>
      </div>
      <div class="form-group">
        <%= f.label :password, '비밀번호' %>
        <%= f.password_field :password, placeholder: '••••••••', autocomplete: 'current-password' %>
      </div>
      <%= f.submit '로그인', class: 'btn btn-primary', style: 'width: 100%; margin-top: 8px;' %>
    <% end %>
  </div>
</div>
